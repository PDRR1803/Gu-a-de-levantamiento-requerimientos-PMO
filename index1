    <!-- Controles -->
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-8 bg-black/60 backdrop-blur-xl border border-white/10 px-8 py-3 rounded-full shadow-2xl z-50">
        <button onclick="prevSlide()" class="hover:text-lime transition text-white"><i class="fa-solid fa-chevron-left text-xl"></i></button>
        <div id="nav-dots-container" class="flex gap-3"></div>
        <button onclick="nextSlide()" class="hover:text-lime transition text-white"><i class="fa-solid fa-chevron-right text-xl"></i></button>
    </div>

    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide-container');
        const dotsContainer = document.getElementById('nav-dots-container');
        const slideNumDisplay = document.getElementById('slide-num');

        slides.forEach((slide, index) => {
            const dot = document.createElement('div');
            dot.className = `nav-dot ${index === 0 ? 'active' : ''}`;
            dot.onclick = () => goToSlide(index);
            dotsContainer.appendChild(dot);
        });

        const dots = document.querySelectorAll('.nav-dot');

        function updateUI() {
            slides.forEach((s, i) => {
                s.classList.toggle('active', i === currentSlide);
                dots[i].classList.toggle('active', i === currentSlide);
            });
            const title = slides[currentSlide].dataset.title;
            slideNumDisplay.innerText = `LÁMINA ${currentSlide + 1} / ${slides.length} - ${title}`;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function nextSlide() { if (currentSlide < slides.length - 1) { currentSlide++; updateUI(); } }
        function prevSlide() { if (currentSlide > 0) { currentSlide--; updateUI(); } }
        function goToSlide(index) { currentSlide = index; updateUI(); }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight' || e.key === 'Space') nextSlide();
            if (e.key === 'ArrowLeft') prevSlide();
        });
    </script>
